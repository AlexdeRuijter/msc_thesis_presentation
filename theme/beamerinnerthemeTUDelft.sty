% --- 5. INNER THEME (theme/beamerinnerthemeTUDelft.sty) ---
\ProvidesPackage{beamerinnerthemeTUDelft}
% Controls blocks, lists, and the title page

\setbeamertemplate{itemize items}[circle] % Use circles for bullets


% 1. Title Slide Background
\defbeamertemplate*{title page}{custom}[1][]
{
    \begingroup

    \begin{tikzpicture}[remember picture, overlay]
        % Background Image
        \node[anchor=north west, inner sep=0pt] at (current page.north west) {
            \includegraphics[width=\paperwidth, height=\paperheight]{\titleBgImage}
        };
        
        % Cyan Overlay/Shape (The "Notch" or stylistic bar often found in TU Delft layouts)
        \fill[TUcyan] (current page.north west) rectangle ($(current page.south west) + (\paperwidth, 0)$);
        \node[anchor=north west] at ($(current page.north west) + (1cm, -0.5cm)$) {
           % Logo Placement
            \resizebox{3cm}{!}{\TUDelftLogoWhite} 
        };
        
        % Title Text Block (Bottom Left)
        \node[anchor=south west, align=left, text width=0.8\paperwidth] at ($(current page.south west) + (1cm, 2cm)$) {
            \usebeamerfont{title}\textcolor{TUwhite}{\inserttitle}\\[0.5em]
            \usebeamerfont{subtitle}\textcolor{TUwhite}{\insertsubtitle}
        };
        
        % Author/Date Block
        \node[anchor=south west, align=left] at ($(current page.south west) + (1cm, 1cm)$) {
            {\usebeamerfont{author}\color{TUwhite}\insertauthor \quad | \quad \insertdate}
        };

    \end{tikzpicture}
    \endgroup
}




